acoustic_features/*.npy

# eBird range data (large)
range_data/ebird/*.txt
range_data/ebird/*.csv.gz

# BCR shapefile (5MB, re-downloadable from USDA Forest Service RDS-2021-0001)
range_data/bcr_shapefile/

# External tools (cloned/forked)
_external/

# Analysis: Stan exes + chain CSVs + full posteriors
analysis/*.exe
analysis/stan_csvs/
analysis/production_*/posterior_full.parquet

# Python
